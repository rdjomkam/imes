# --- DeepSeek (text/analysis — required) -----------------------------------
# Used by the strategy & learn pipelines AND by the document agents' analysis
# stage (Claude only handles document vision). Get a key at https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-...
# Optional. Defaults to "deepseek-chat" (≈ deepseek-v4-flash, non-reasoning JSON).
DEEPSEEK_MODEL=deepseek-chat

# --- Anthropic / Claude (document vision — required for /api/document) ------
# Used ONLY by the 4 document agents (manifeste, crédit, rapport, offre) to
# transcribe the uploaded PDF/image. The strategy & learn pipelines do NOT use it.
ANTHROPIC_API_KEY=sk-ant-...
# Optional. Defaults to "claude-sonnet-4-6" (good PDF + image support).
VISION_MODEL=claude-sonnet-4-6

# --- Tavily (web research — required for the strategy pipeline) -------------
# Used by the "contexte public" node of the strategy agent and by the learn
# pipeline (3 search queries per company). Get a key at https://tavily.com
TAVILY_API_KEY=tvly-...

# --- Server -----------------------------------------------------------------
# In Coolify, PORT is injected automatically — leave this commented in prod.
# PORT=5174

# --- Persistent profile (optional, recommended for Coolify) -----------------
# Path to the active company profile file. Mount a volume to this directory in
# Coolify (e.g. /data) so the learned profile survives redeploys. Leave empty
# to use the bundled file at /app/company-profile.json (resets on redeploy).
# PROFILE_PATH=/data/company-profile.json
